---
import '../styles/global.css';
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} · ${SITE.title}` : SITE.title;
const path = Astro.url.pathname;
const navItems = [
  { href: '/posts', label: '文章' },
  { href: '/books', label: '书单' },
  { href: '/about', label: '关于' },
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6f1e6" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={title ? 'article' : 'website'} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-screen-webfont@1.7.0/style.css"
    />
    <slot name="head" />
  </head>
  <body>
    <!-- 晨光氛围：两团极慢漂移的暖色光晕 -->
    <div class="sky" aria-hidden="true">
      <i class="glow glow-dawn"></i>
      <i class="glow glow-tea"></i>
    </div>

    <header class="site-header">
      <nav class="wide" aria-label="主导航">
        <a class="brand" href="/">
          <svg class="mark" viewBox="0 0 32 32" width="22" height="22" aria-hidden="true">
            <circle cx="16" cy="16" r="14" fill="currentColor" opacity="0.92" />
            <path
              d="M9 17c2 4 5 6 7 6s5-2 7-6"
              stroke="#f6f1e6"
              stroke-width="2.5"
              fill="none"
              stroke-linecap="round"
            />
          </svg>
          {SITE.title}
        </a>
        <div class="links">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={path.startsWith(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>
        <form class="search" action="/search" method="get">
          <input type="search" name="q" placeholder="搜索…" aria-label="站内搜索" />
        </form>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="ornament" aria-hidden="true"><i></i></div>
      <p class="motto">慢慢走，欣赏啊。</p>
      <p class="meta">{SITE.title} · <a href="/rss.xml">RSS 订阅</a></p>
    </footer>
  </body>
</html>

<style>
  /* ——— 氛围背景 ——— */
  .sky {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background:
      radial-gradient(ellipse 90% 60% at 85% -10%, rgba(243, 225, 207, 0.9), transparent 60%),
      var(--paper);
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }
  .glow-dawn {
    width: 60vmax;
    height: 60vmax;
    top: -22vmax;
    left: -14vmax;
    background: radial-gradient(circle, rgba(230, 168, 110, 0.32), transparent 65%);
    animation: drift-a 52s ease-in-out infinite alternate;
  }
  .glow-tea {
    width: 55vmax;
    height: 55vmax;
    right: -18vmax;
    bottom: -24vmax;
    background: radial-gradient(circle, rgba(167, 181, 140, 0.28), transparent 65%);
    animation: drift-b 64s ease-in-out infinite alternate;
  }
  @keyframes drift-a {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(9vmax, 7vmax) scale(1.12); }
  }
  @keyframes drift-b {
    from { transform: translate(0, 0) scale(1.08); }
    to { transform: translate(-8vmax, -6vmax) scale(1); }
  }

  /* ——— 导航 ——— */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(246, 241, 230, 0.78);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(221, 210, 189, 0.6);
  }
  nav {
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1.6rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    color: var(--ink);
  }
  .brand .mark { color: var(--persimmon); }
  .brand:hover { color: var(--persimmon-deep); }
  .links { display: flex; gap: 1.4rem; }
  .links a {
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: 0.14em;
    color: var(--ink-soft);
    padding: 0.15rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.25s var(--ease-out), border-color 0.25s var(--ease-out);
  }
  .links a:hover { color: var(--persimmon); }
  .links a[aria-current='page'] {
    color: var(--persimmon-deep);
    border-bottom-color: var(--persimmon);
  }
  .search { margin-left: auto; }
  .search input {
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 0.35rem 1rem;
    background: rgba(255, 253, 246, 0.85);
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--ink);
    width: 9.5rem;
    transition: width 0.35s var(--ease-out), border-color 0.25s;
  }
  .search input:focus { width: 13rem; border-color: var(--persimmon); }
  .search input::placeholder { color: var(--ink-mute); }

  main {
    padding: 0 1.25rem 5rem;
    min-height: 60vh;
  }

  /* ——— 页脚 ——— */
  .site-footer {
    border-top: 1px solid rgba(221, 210, 189, 0.6);
    text-align: center;
    padding: 2.5rem 1.25rem 3rem;
  }
  .site-footer .ornament { margin: 0 auto 1.2rem; }
  .motto {
    font-family: var(--font-display);
    color: var(--ink-soft);
    letter-spacing: 0.3em;
    text-indent: 0.3em;
    margin: 0 0 0.6rem;
  }
  .meta { color: var(--ink-mute); font-size: 0.85rem; margin: 0; }

  @media (max-width: 640px) {
    nav { gap: 0.9rem 1.2rem; }
    .search { margin-left: 0; width: 100%; }
    .search input, .search input:focus { width: 100%; }
  }
</style>
