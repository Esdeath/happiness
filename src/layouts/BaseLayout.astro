---
import '../styles/global.css';
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string; // og:image 绝对 URL；缺省用站点默认分享图
  type?: 'website' | 'article';
  publishedDate?: Date;
  jsonLd?: object | object[]; // 注入的结构化数据
  noindex?: boolean; // 低价值页（搜索/404）置为 true
}

const {
  title,
  description = SITE.description,
  image,
  type = title ? 'article' : 'website',
  publishedDate,
  jsonLd,
  noindex = false,
} = Astro.props;
const pageTitle = title ? `${title} · ${SITE.title}` : SITE.title;
const path = Astro.url.pathname;
const canonical = new URL(path, Astro.site).href;
const ogImage = image ?? new URL(SITE.ogImage, Astro.site).href;
const ogLocale = SITE.locale.replace('-', '_'); // zh-CN → zh_CN
const schemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const navItems = [
  { href: '/posts', label: '文章' },
  { href: '/books', label: '书单' },
  { href: '/about', label: '关于' },
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fff8eb" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImage} />
    {type === 'article' && publishedDate && (
      <meta property="article:published_time" content={publishedDate.toISOString()} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Noto+Sans+SC:wght@400;500;700;800&family=ZCOOL+KuaiLe&display=swap"
    />
    <slot name="head" />
  </head>
  <body>
    <div class="sky" aria-hidden="true"></div>

    <header class="site-header">
      <nav class="wide" aria-label="主导航">
        <a class="brand" href="/">
          <span class="mascot mascot-sm" aria-hidden="true">
            <span class="mascot-face">
              <span class="eye eye-l"></span>
              <span class="eye eye-r"></span>
              <span class="cheek cheek-l"></span>
              <span class="cheek cheek-r"></span>
              <span class="mouth"></span>
            </span>
          </span>
          {SITE.title}
        </a>
        <div class="links">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={path.startsWith(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>
        <form class="search" action="/search" method="get">
          <input type="search" name="q" placeholder="搜点什么…" aria-label="站内搜索" />
        </form>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="ornament" aria-hidden="true"><i></i><i></i><i></i></div>
      <p class="motto">慢慢走，欣赏啊 ✿</p>
      <p class="meta">{SITE.title} · <a href="/rss.xml">RSS 订阅</a></p>
    </footer>
  </body>
</html>

<style>
  .sky {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(217, 239, 251, 0.68), transparent 14rem),
      radial-gradient(circle at 14% 8%, rgba(255, 214, 107, 0.22), transparent 16rem),
      var(--paper);
  }
  /* 吉祥物核心样式定义在 global.css（供各处复用）；
     这里只补充导航内的交互 */

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(255, 250, 240, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(234, 223, 206, 0.76);
  }
  nav {
    padding: 0.7rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0;
    color: var(--ink);
  }
  .brand .mascot { transition: transform 0.4s var(--ease-spring); }
  .brand:hover { color: var(--leaf-deep); }
  .brand:hover .mascot { transform: rotate(-10deg) scale(1.1); }
  .links { display: flex; gap: 0.5rem; }
  .links a {
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0;
    color: var(--ink-soft);
    padding: 0.18rem 0.28rem;
    border-radius: 6px;
    background: transparent;
    transition: transform 0.22s var(--ease-spring), color 0.22s var(--ease-out),
      background 0.22s var(--ease-out), box-shadow 0.22s var(--ease-out);
  }
  .links a:hover {
    color: var(--coral-deep);
    background: rgba(255, 232, 225, 0.55);
  }
  .links a[aria-current='page'] {
    color: var(--leaf-deep);
    background: rgba(228, 243, 220, 0.64);
  }
  .search { margin-left: auto; }
  .search input {
    border: 1px solid var(--hairline);
    border-radius: var(--r-card);
    padding: 0.36rem 0.72rem;
    background: rgba(255, 253, 248, 0.78);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--ink);
    width: 10rem;
    transition: width 0.35s var(--ease-out), border-color 0.25s;
  }
  .search input:focus { width: 12rem; border-color: var(--honey-deep); }
  .search input::placeholder { color: var(--ink-mute); }

  main {
    padding: 0 1.25rem 4.2rem;
    min-height: 60vh;
  }

  .site-footer {
    border-top: 1px solid rgba(234, 223, 206, 0.76);
    text-align: center;
    padding: 2rem 1.25rem 2.5rem;
    background: rgba(255, 253, 248, 0.42);
  }
  .site-footer .ornament { margin: 0 auto 1.2rem; }
  .motto {
    font-family: var(--font-body);
    font-weight: 800;
    color: var(--ink-soft);
    letter-spacing: 0;
    margin: 0 0 0.6rem;
  }
  .meta { color: var(--ink-mute); font-size: 0.85rem; margin: 0; }

  @media (max-width: 640px) {
    nav { gap: 0.8rem 1rem; }
    .search { margin-left: 0; width: 100%; }
    .search input, .search input:focus { width: 100%; }
  }
</style>
