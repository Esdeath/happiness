---
interface Props {
  links: { platform: string; url: string }[];
}
const { links } = Astro.props;
---

{links.length > 0 && (
  <div class="purchase" role="group" aria-label="购买渠道">
    <span class="label">去购买</span>
    {links.map((link) => (
      <a
        href={link.url}
        target="_blank"
        rel="nofollow sponsored noopener"
        aria-label={`在 ${link.platform} 购买（新窗口打开）`}
      >
        {link.platform} ↗
      </a>
    ))}
  </div>
)}

<style>
  .purchase {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin: 1.6rem 0 0;
  }
  .label {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--ink-soft);
  }
  .purchase a {
    font-family: var(--font-display);
    background: var(--persimmon);
    color: var(--surface);
    padding: 0.4rem 1.2rem;
    border-radius: 999px;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    box-shadow: 0 4px 14px rgba(182, 84, 39, 0.25);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out),
      background 0.3s;
  }
  .purchase a:hover {
    background: var(--persimmon-deep);
    color: var(--surface);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(182, 84, 39, 0.32);
  }
  .purchase a:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--paper), 0 0 0 5px var(--persimmon);
  }
</style>
