---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/content';
import TagList from './TagList.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}
const { post } = Astro.props;
---

<article class="card">
  <p class="meta">
    <time>{formatDate(post.data.pubDate)}</time>
    {post.data.interviewee && <span class="badge">访谈</span>}
  </p>
  <h3><a href={`/posts/${post.id}`}>{post.data.title}</a></h3>
  <p class="summary">{post.data.summary}</p>
  <TagList tags={post.data.tags} />
</article>

<style>
  .card {
    position: relative;
    padding: 1.05rem 0;
    border-bottom: 1px solid var(--hairline);
    transition: transform 0.22s var(--ease-out);
  }
  .card:hover {
    transform: translateX(3px);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink-mute);
    font-size: 0.82rem;
    font-weight: 700;
    margin: 0 0 0.32rem;
  }
  .badge {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0;
    color: var(--leaf-deep);
    background: rgba(228, 243, 220, 0.78);
    border-radius: var(--r-pill);
    padding: 0.04rem 0.5rem;
  }
  h3 {
    position: relative;
    z-index: 1;
    font-size: 1.16rem;
    margin: 0 0 0.28rem;
    overflow-wrap: anywhere;
  }
  h3 a {
    display: block;
    color: var(--ink);
    overflow-wrap: anywhere;
    transition: color 0.25s var(--ease-out);
  }
  h3 a:hover { color: var(--primary-deep); }
  .summary {
    position: relative;
    z-index: 1;
    color: var(--ink-soft);
    margin: 0 0 0.54rem;
    font-size: 0.96rem;
    line-height: 1.72;
    overflow-wrap: anywhere;
  }
  .card :global(.tags) {
    position: relative;
    z-index: 1;
  }
</style>
