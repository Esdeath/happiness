---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/content';
import TagList from './TagList.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}
const { post } = Astro.props;
---

<article class="card">
  <p class="meta">
    <time>{formatDate(post.data.pubDate)}</time>
    {post.data.interviewee && <span class="badge">访谈</span>}
  </p>
  <h3><a href={`/posts/${post.id}`}>{post.data.title}</a></h3>
  <p class="summary">{post.data.summary}</p>
  <TagList tags={post.data.tags} />
</article>

<style>
  .card {
    position: relative;
    padding: 1.6rem 0 1.7rem;
    border-bottom: 1px solid var(--hairline);
  }
  .card::before {
    content: "";
    position: absolute;
    left: -1.25rem;
    top: 1.9rem;
    bottom: 1.9rem;
    width: 3px;
    border-radius: 3px;
    background: var(--persimmon);
    opacity: 0;
    transition: opacity 0.3s var(--ease-out);
  }
  .card:hover::before { opacity: 0.85; }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink-mute);
    font-size: 0.85rem;
    margin: 0 0 0.45rem;
  }
  .badge {
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--sage-deep);
    background: var(--sage-soft);
    border-radius: 999px;
    padding: 0.05rem 0.6rem;
  }
  h3 {
    font-size: 1.25rem;
    margin: 0 0 0.4rem;
  }
  h3 a {
    color: var(--ink);
    transition: color 0.25s var(--ease-out);
  }
  h3 a:hover { color: var(--persimmon); }
  .summary {
    color: var(--ink-soft);
    margin: 0 0 0.7rem;
  }
</style>
