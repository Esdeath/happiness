---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  book: CollectionEntry<'books'>;
}
const { book } = Astro.props;
---

<a class="book-card" href={`/books/${book.id}`}>
  <div class="cover">
    <Image src={book.data.cover} alt={`《${book.data.title}》封面`} width={340} />
  </div>
  <h3>{book.data.title}</h3>
  <p class="author">{book.data.author}</p>
  <p class="one-liner">{book.data.oneLiner}</p>
</a>

<style>
  .book-card {
    display: block;
    color: var(--ink);
    padding: 0.35rem;
    border-radius: var(--r-card);
    transition: background 0.22s var(--ease-out);
  }
  .book-card:hover { background: rgba(255, 253, 248, 0.58); }

  .cover {
    position: relative;
    border-radius: 4px 8px 8px 4px;
    overflow: hidden;
    aspect-ratio: 5 / 7;
    box-shadow: 0 8px 18px rgba(81, 66, 61, 0.13);
    transition: transform 0.28s var(--ease-spring), box-shadow 0.28s var(--ease-out);
  }
  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cover::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 12px;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.18),
      rgba(255, 255, 255, 0.22) 45%,
      rgba(0, 0, 0, 0.1) 70%,
      transparent
    );
    mix-blend-mode: soft-light;
    pointer-events: none;
  }
  .cover::after {
    content: "";
    position: absolute;
    inset: 1px 1px 1px auto;
    width: 5px;
    border-radius: 0 7px 7px 0;
    background: repeating-linear-gradient(
      to right,
      rgba(255, 255, 255, 0.55) 0 1px,
      rgba(0, 0, 0, 0.08) 1px 2px
    );
    pointer-events: none;
  }

  .book-card:hover .cover {
    transform: translateY(-4px) rotate(-1deg);
    box-shadow: 0 12px 26px rgba(81, 66, 61, 0.16);
  }

  h3 {
    font-size: 1rem;
    font-weight: 800;
    margin: 1rem 0 0.15rem;
    transition: color 0.25s var(--ease-out);
  }
  .book-card:hover h3 { color: var(--primary-deep); }
  .author {
    color: var(--ink-mute);
    font-size: 0.85rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
  }
  .one-liner {
    color: var(--ink-soft);
    font-size: 0.88rem;
    line-height: 1.62;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
