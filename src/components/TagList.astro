---
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
---

<ul class="tags">
  {tags.map((tag) => (
    <li><a href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a></li>
  ))}
</ul>

<style>
  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.38rem;
    flex-wrap: wrap;
  }
  .tags a {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0;
    color: var(--sky-deep);
    border: 0;
    background: rgba(229, 232, 255, 0.58);
    padding: 0.08rem 0.46rem;
    border-radius: var(--r-pill);
    transition: all 0.2s var(--ease-out);
  }
  .tags a:hover {
    color: #fffdf7;
    background: var(--bluebell);
  }
</style>
