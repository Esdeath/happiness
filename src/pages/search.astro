---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="搜索" description="搜索本站的文章与书籍。" noindex>
  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </Fragment>
  <div class="page-head rise">
    <p class="eyebrow">搜 索</p>
    <h1>找点什么</h1>
    <p class="lede note">搜索索引在构建时生成，本地 dev 模式下不可用（用 npm run build && npm run preview 验证）。</p>
  </div>
  <div class="container rise" style="animation-delay: 120ms">
    <div id="search"></div>
    <noscript><p>搜索功能需要启用 JavaScript。</p></noscript>
  </div>
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof PagefindUI === 'undefined') return; // dev 模式未生成索引
      const ui = new PagefindUI({
        element: '#search',
        showSubResults: true,
        translations: {
          placeholder: '搜索文章与书籍…',
          zero_results: '没有找到「[SEARCH_TERM]」相关的内容',
        },
      });
      const q = new URLSearchParams(location.search).get('q');
      if (q) ui.triggerSearch(q);
    });
  </script>
</BaseLayout>

<style>
  .note { font-size: 0.85rem; color: var(--ink-mute); }
  #search {
    --pagefind-ui-primary: var(--persimmon);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--surface);
    --pagefind-ui-border: var(--hairline);
    --pagefind-ui-tag: var(--persimmon-soft);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 12px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-font: var(--font-body);
  }
</style>
