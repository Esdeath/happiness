---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagList from '../../components/TagList.astro';
import Giscus from '../../components/Giscus.astro';
import { formatDate, ogImageUrl, sortByDateDesc } from '../../lib/content';
import { blogPostingSchema, breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const sorted = sortByDateDesc(posts);
  return posts.map((post) => {
    const related = sorted
      .filter(
        (p) =>
          p.id !== post.id &&
          p.data.tags.some((t) => post.data.tags.includes(t)),
      )
      .slice(0, 3);
    return { params: { slug: post.id }, props: { post, related } };
  });
}

const { post, related } = Astro.props;
const { Content } = await render(post);
const site = Astro.site!;
const image = await ogImageUrl(post.data.cover, site);
const jsonLd = [
  blogPostingSchema(post, site, image),
  breadcrumbSchema(
    [
      { name: '首页', path: '/' },
      { name: '文章', path: '/posts' },
      { name: post.data.title, path: `/posts/${post.id}/` },
    ],
    site,
  ),
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.summary}
  type="article"
  publishedDate={post.data.pubDate}
  image={image}
  jsonLd={jsonLd}
>
  <article class="container" data-pagefind-body>
    <nav class="crumb rise" aria-label="返回">
      <a href="/posts">← 返回文章</a>
    </nav>
    <header class="post-head rise" style="animation-delay: 100ms">
      <p class="meta"><time>{formatDate(post.data.pubDate)}</time></p>
      <h1>{post.data.title}</h1>
      <div class="tags-row"><TagList tags={post.data.tags} /></div>
    </header>

    {post.data.cover && (
      <Image class="cover rise" src={post.data.cover} alt="" width={920} style="animation-delay: 200ms" />
    )}

    {post.data.interviewee && (
      <aside class="interviewee rise" style="animation-delay: 240ms" aria-label="受访者简介">
        <strong>受访者 · {post.data.interviewee}</strong>
        {post.data.intervieweeBio && <p>{post.data.intervieweeBio}</p>}
      </aside>
    )}

    <div class="prose rise" style="animation-delay: 280ms">
      <Content />
    </div>
  </article>

  {related.length > 0 && (
    <nav class="related container" aria-label="相关文章" data-pagefind-ignore>
      <h2>相关文章</h2>
      <ul>
        {related.map((p) => (
          <li>
            <a href={`/posts/${p.id}/`}>{p.data.title}</a>
            <span>{p.data.summary}</span>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <div class="container">
    <Giscus />
  </div>
</BaseLayout>

<style>
  .crumb { padding: 2rem 0 0; }
  .crumb a {
    font-family: var(--font-display);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    color: var(--ink-mute);
  }
  .crumb a:hover { color: var(--persimmon); }

  .post-head { text-align: center; padding: 2.6rem 0 1.6rem; }
  .meta {
    font-family: var(--font-display);
    color: var(--ink-mute);
    font-size: 0.88rem;
    letter-spacing: 0.2em;
    margin: 0 0 0.9rem;
  }
  h1 {
    font-size: clamp(1.8rem, 4.5vw, 2.5rem);
    font-weight: 900;
    margin: 0 0 1.1rem;
  }
  .tags-row { display: flex; justify-content: center; }

  .cover {
    border-radius: 12px;
    margin: 0.8rem 0 1.6rem;
    box-shadow: var(--shadow-card);
  }

  .interviewee {
    background: rgba(255, 253, 246, 0.8);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    padding: 1rem 1.4rem;
    margin: 1.6rem 0;
  }
  .interviewee strong {
    font-family: var(--font-display);
    letter-spacing: 0.06em;
  }
  .interviewee p {
    margin: 0.35rem 0 0;
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  .related {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--hairline);
  }
  .related h2 {
    font-size: 1.2rem;
    font-weight: 900;
    margin: 0 0 1.1rem;
    padding-left: 0.8rem;
    border-left: 4px solid var(--persimmon);
  }
  .related ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 1.1rem; }
  .related a {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--ink);
  }
  .related a:hover { color: var(--persimmon); }
  .related span {
    display: block;
    margin-top: 0.2rem;
    color: var(--ink-mute);
    font-size: 0.9rem;
  }
</style>
