---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { sortByDateDesc } from '../../lib/content';

const posts = sortByDateDesc(
  await getCollection('posts', ({ data }) => !data.draft),
);
---

<BaseLayout title="文章" description="关于幸福的文章与访谈，按时间排列。">
  <div class="page-head page-head-center rise">
    <h1>幸福的文字</h1>
    <p class="lede">共 {posts.length} 篇，按时间从新到旧排列。</p>
  </div>
  <div class="container">
    {posts.map((post, i) => (
      <div class="rise" style={`animation-delay: ${i * 70 + 120}ms`}>
        <PostCard post={post} />
      </div>
    ))}
  </div>
</BaseLayout>
