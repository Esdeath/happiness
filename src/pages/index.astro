---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { sortByDateDesc } from '../lib/content';
import { websiteSchema, organizationSchema } from '../lib/schema';

const posts = sortByDateDesc(
  await getCollection('posts', ({ data }) => !data.draft),
).slice(0, 4);
const books = sortByDateDesc(
  await getCollection('books', ({ data }) => !data.draft),
).slice(0, 4);

const jsonLd = [websiteSchema(Astro.site!), organizationSchema(Astro.site!)];
---

<BaseLayout jsonLd={jsonLd}>
  <section class="home-hero rise">
    <span class="mascot mascot-home" aria-hidden="true">
      <span class="mascot-face">
        <span class="eye eye-l"></span>
        <span class="eye eye-r"></span>
        <span class="cheek cheek-l"></span>
        <span class="cheek cheek-r"></span>
        <span class="mouth"></span>
      </span>
    </span>
    <h1>庆祝每一天</h1>
  </section>

  <section class="home-grid wide">
    <div class="panel rise" style="animation-delay: 80ms">
      <header class="section-head">
        <div>
          <p>最近写下</p>
          <h2>文章</h2>
        </div>
        <a href="/posts">全部</a>
      </header>
      <div class="post-list">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>

    <aside class="panel books-panel rise" style="animation-delay: 140ms">
      <header class="section-head">
        <div>
          <p>慢慢翻</p>
          <h2>书单</h2>
        </div>
        <a href="/books">全部</a>
      </header>
      <div class="mini-books">
        {books.map((book) => (
          <a class="mini-book" href={`/books/${book.id}`}>
            <Image src={book.data.cover} alt={`《${book.data.title}》封面`} width={92} />
            <span>
              <strong>{book.data.title}</strong>
              <em>{book.data.author}</em>
            </span>
          </a>
        ))}
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .home-hero {
    width: 100%;
    max-width: var(--width-wide);
    margin: clamp(1.1rem, 3vw, 1.9rem) auto clamp(1.45rem, 3.6vw, 2.4rem);
    padding: clamp(1.5rem, 4vw, 2.8rem) 0 clamp(1.3rem, 3.2vw, 2.1rem);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.75rem, 2.4vw, 1.35rem);
    text-align: center;
    border-bottom: 1px solid rgba(234, 223, 206, 0.82);
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 214, 107, 0.16), transparent 14rem),
      linear-gradient(90deg, transparent, rgba(228, 243, 220, 0.5), transparent) left bottom / 100% 1px no-repeat;
  }
  .mascot-home {
    width: clamp(58px, 7vw, 82px);
    height: clamp(58px, 7vw, 82px);
    flex: none;
  }
  .home-hero h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(2.15rem, 6vw, 4.35rem);
    line-height: 1.08;
    white-space: nowrap;
    overflow-wrap: anywhere;
  }

  .home-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(17rem, 0.85fr);
    gap: clamp(1.4rem, 4vw, 2.4rem);
    align-items: start;
  }
  .panel {
    min-width: 0;
  }
  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--hairline);
    margin-bottom: 0.2rem;
  }
  .section-head p {
    margin: 0 0 0.12rem;
    color: var(--leaf-deep);
    font-size: 0.82rem;
    font-weight: 800;
  }
  .section-head h2 {
    margin: 0;
    font-size: clamp(1.45rem, 3vw, 2rem);
  }
  .section-head a {
    color: var(--ink-mute);
    font-weight: 800;
    font-size: 0.9rem;
  }
  .section-head a:hover {
    color: var(--primary-deep);
  }
  .post-list {
    display: grid;
  }
  .books-panel {
    background: rgba(255, 253, 248, 0.56);
    border: 1px solid rgba(234, 223, 206, 0.78);
    border-radius: var(--r-card);
    padding: 1rem;
  }
  .mini-books {
    display: grid;
    gap: 0.65rem;
  }
  .mini-book {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    padding: 0.5rem;
    border-radius: var(--r-card);
    color: var(--ink);
    transition: background 0.2s var(--ease-out), transform 0.2s var(--ease-out);
  }
  .mini-book:hover {
    background: var(--surface);
    transform: translateY(-2px);
  }
  .mini-book :global(img) {
    width: 42px;
    aspect-ratio: 5 / 7;
    object-fit: cover;
    border-radius: 3px 6px 6px 3px;
    box-shadow: 0 5px 12px rgba(86, 66, 48, 0.14);
  }
  .mini-book span {
    min-width: 0;
  }
  .mini-book strong {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.95rem;
  }
  .mini-book em {
    display: block;
    color: var(--ink-mute);
    font-style: normal;
    font-size: 0.82rem;
    font-weight: 700;
  }

  @media (max-width: 780px) {
    .home-grid {
      grid-template-columns: 1fr;
    }
    .books-panel {
      background: transparent;
      border: 0;
      padding: 0;
    }
  }
  @media (max-width: 520px) {
    .home-hero {
      margin-top: 0.7rem;
      padding-block: 1.2rem 1.4rem;
      gap: 0.7rem;
    }
    .home-hero h1 {
      font-size: clamp(1.9rem, 10vw, 2.7rem);
    }
    .section-head {
      align-items: center;
    }
  }
</style>
