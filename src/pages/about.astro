---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

const site = Astro.site!;
// AboutPage + Person/Organization：向搜索与 AI 引擎说明"这个站由谁、为何而办"，
// 是 E-E-A-T（经验/专业/权威/可信）信号。站主填上真实姓名后可信度更高。
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `关于 · ${SITE.title}`,
  url: new URL('/about', site).href,
  inLanguage: SITE.locale,
  mainEntity: {
    '@type': 'Organization',
    name: SITE.title,
    description: SITE.description,
    url: new URL('/', site).href,
    founder: { '@type': 'Person', name: SITE.author },
  },
};
---

<BaseLayout
  title="关于"
  description="「追寻幸福」是一个关于幸福的中文内容站：分享有据可循的思考、人物访谈与精选书单。"
  jsonLd={jsonLd}
>
  <div class="page-head rise">
    <h1>关于本站</h1>
  </div>
  <div class="prose container rise" style="animation-delay: 120ms">
    <p>
      「追寻幸福」是一个关于幸福的中文内容站。这里做三件事：写下关于幸福的思考、与不同的人对话，
      以及推荐那些真正值得慢慢读的书。
    </p>
    <p>
      我们偏好<strong>有据可循</strong>的内容——文章尽量引用心理学与哲学的研究与著作，
      点明出处，而不是堆砌励志口号。书单里的每一本，都附上一篇独立的读书笔记，
      梳理它到底在讲什么、哪些观点值得记住、又能怎样用在日常里。
    </p>
    <p>
      幸福不是终点，而是一种行进的方式。希望你在这里慢下来，找到属于自己的答案。
    </p>

    <h2>关于作者</h2>
    <p class="note">
      （站主可在 <code>src/pages/about.astro</code> 中替换为真实的自我介绍，
      并把 <code>src/config.ts</code> 里的 <code>SITE.author</code> 改成真名——
      署名越具体，搜索引擎与 AI 越愿意把内容当作可信来源引用。）
    </p>

    <h2>联系与订阅</h2>
    <p>
      想持续读到更新，可以订阅 <a href="/rss.xml">RSS</a>；也欢迎从<a href="/posts">文章</a>
      或<a href="/books">书单</a>开始随意翻阅。
    </p>
  </div>
</BaseLayout>

<style>
  .prose h2 {
    font-size: 1.3rem;
    font-weight: 900;
    margin: 2rem 0 0.8rem;
    padding-left: 0.8rem;
    border-left: 5px solid var(--peach);
  }
  .note { color: var(--ink-mute); font-size: 0.9rem; }
</style>
