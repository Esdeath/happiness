---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面不存在">
  <div class="lost container rise">
    <p class="code">四〇四</p>
    <h1>这一页是空白的</h1>
    <p class="hint">你要找的页面不在这里。不妨从<a href="/">首页</a>重新出发，或者去<a href="/books">书单</a>里随便翻翻。</p>
  </div>
</BaseLayout>

<style>
  .lost { text-align: center; padding: 6rem 0 4rem; }
  .code {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 5rem);
    font-weight: 900;
    letter-spacing: 0.2em;
    color: var(--persimmon-soft);
    -webkit-text-stroke: 1.5px var(--persimmon);
    margin: 0 0 0.5rem;
  }
  h1 { font-size: 1.6rem; margin: 0 0 1rem; }
  .hint { color: var(--ink-soft); }
</style>
